// helix.ai — Prisma schema.
//
// `url`       → DATABASE_URL        → app_user (runtime + Prisma Client + tests).
// `directUrl` → DIRECT_DATABASE_URL → owner    (used by `prisma migrate`/`db`).
//
// The schema below mirrors the hand-authored SQL migration. The migration is the
// source of truth for everything Prisma cannot express: RLS, FORCE RLS, policies,
// the append-only audit trigger, and the least-privilege GRANTs to app_user.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  owner
  admin
  lead
  member

  @@map("role")
}

enum ApprovalMode {
  always
  threshold
  never

  @@map("approval_mode")
}

enum DocumentVisibility {
  open
  restricted
  confidential

  @@map("document_visibility")
}

/// Loop autonomy level (Schritt D, plan §4) — how sharply the loop acts on a
/// deviation. 'report' = flag + notify (Default); 'suggest' = flag carries a
/// correction proposal the human triggers; 'autonomous' = reserved for Schritt E
/// (behaves like 'suggest' until then). Stored per org on org_settings.
enum LoopAutonomy {
  report
  suggest
  autonomous

  @@map("loop_autonomy")
}

enum ActorType {
  human
  agent

  @@map("actor_type")
}

enum DocumentSource {
  upload
  manual
  transcript

  @@map("document_source")
}

enum ChatRole {
  user
  assistant

  @@map("chat_role")
}

enum SkillRunStatus {
  running
  awaiting_approval
  approved
  rejected
  completed
  failed

  @@map("skill_run_status")
}

enum SkillStepStatus {
  pending
  done
  failed

  @@map("skill_step_status")
}

enum ApprovalStatus {
  pending
  approved
  rejected

  @@map("approval_status")
}

/// How a run was executed. 'live' = real execution (acting steps run).
/// 'simulation' = dry-run ("Probelauf"): guardrails/approval checks still run
/// and are shown, but acting steps are SIMULATED, never executed. Value/activity
/// aggregations filter mode='live' — a simulation never counts as a real run.
enum SkillRunMode {
  live
  simulation

  @@map("skill_run_mode")
}

/// Tenant root. RLS ENABLE + FORCE with a SELF-ROW policy keyed on `id` (which
/// is the tenant key), so a tenant can see/modify only its own org row.
/// `id` is an internal UUID; `clerkOrgId` links it to the verified Clerk org.
model Organization {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkOrgId String   @unique @map("clerk_org_id")
  name       String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  memberships    Membership[]
  knowledgeItems KnowledgeItem[]
  auditLogs      AuditLog[]
  documents      Document[]
  chunks         Chunk[]
  chatMessages   ChatMessage[]
  clients        Client[]
  skillRuns      SkillRun[]
  skillSteps     SkillStep[]
  approvals      Approval[]
  approvalPolicies ApprovalPolicy[]
  visibilityGrants VisibilityGrant[]
  slackInstallations SlackInstallation[]
  slackUserLinks     SlackUserLink[]
  slackProcessedEvents SlackProcessedEvent[]
  settings             OrgSettings?
  chatFeedback         ChatFeedback[]
  artifacts            Artifact[]

  @@map("organizations")
}

/// One Slack workspace (team) mapped to EXACTLY ONE org (tenant-scoped).
/// RLS ENABLE + FORCE. The GLOBAL unique on slack_team_id makes double-mapping
/// structurally impossible. An extra SELECT-only lookup policy (see migration
/// 0006) lets resolveSlackTeam() bootstrap team → org without a tenant context.
/// bot_token_ref is a REFERENCE (e.g. 'env:SLACK_BOT_TOKEN'), never the secret.
model SlackInstallation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  slackTeamId String   @unique @map("slack_team_id")
  botTokenRef String?  @map("bot_token_ref")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("slack_installations")
}

/// A Slack user mapped to a membership of THIS org (tenant-scoped).
/// RLS ENABLE + FORCE. The composite FK (org_id, user_id) → memberships makes a
/// link to a foreign tenant's membership structurally impossible; no link ⇒ the
/// Slack user is treated as role-less (open knowledge only, never acts).
model SlackUserLink {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  slackUserId String   @map("slack_user_id")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  membership   Membership   @relation(fields: [orgId, userId], references: [orgId, userId], onDelete: Cascade)

  @@unique([orgId, slackUserId])
  @@index([orgId])
  @@map("slack_user_links")
}

/// Per-tenant settings (one row per org; org_id IS the PK). RLS ENABLE+FORCE.
/// chat_retention_days: NULL = keep forever; N = purge older messages
/// opportunistically after chat activity (enforceChatRetention, no cron).
model OrgSettings {
  orgId             String   @id @map("org_id") @db.Uuid
  chatRetentionDays Int?     @map("chat_retention_days")
  // Firmendaten (Briefkopf/Fußzeile der Angebots-/Rechnungs-PDFs). Alle
  // optional — ohne Profil bleiben die PDFs neutral, nichts wird erfunden.
  companyName       String?  @map("company_name")
  companyAddress    String?  @map("company_address")
  companyVatId      String?  @map("company_vat_id")
  companyBank       String?  @map("company_bank")
  // Benachrichtigung bei wartenden Freigaben (z. B. Team-Alias). NULL = aus.
  approvalNotifyEmail String? @map("approval_notify_email")
  // Org-wide output language (generated PDFs, outgoing e-mails): 'en' | 'de'.
  // The UI language is per browser (cookie), NOT this field.
  locale            String   @default("en")
  // Value-dashboard assumptions (USD). NULL / missing map key = code default
  // (src/lib/value.ts). Admin-editable, audited as 'policy.changed'.
  valueHourlyRateUsd   Decimal? @map("value_hourly_rate_usd") @db.Decimal(8, 2)
  valueMinutesPerSkill Json?    @map("value_minutes_per_skill")
  // Loop autonomy level (Schritt D). Default 'report' = unchanged (flag + notify).
  // Admin-editable via setLoopAutonomy, audited as 'policy.changed'.
  loopAutonomy      LoopAutonomy @default(report) @map("loop_autonomy")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_settings")
}

/// Idempotency claims for incoming Slack requests (tenant-scoped).
/// RLS ENABLE + FORCE. The unique (org_id, event_key) makes claiming the same
/// Slack event/trigger twice fail atomically — duplicate deliveries are acked
/// with 200 but never processed a second time. Rows only matter for Slack's
/// retry horizon; cleanupProcessedSlackEvents() removes entries older than 24 h.
model SlackProcessedEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  eventKey  String   @map("event_key")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, eventKey])
  @@index([orgId])
  @@map("slack_processed_events")
}

/// Per-skill approval policy (tenant-scoped). RLS ENABLE + FORCE.
/// mode 'never' is only honored for skills without money effects — the engine
/// overrides it for handlesMoney skills (audit 'policy.overridden_failsafe').
model ApprovalPolicy {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String       @map("org_id") @db.Uuid
  skillKey        String       @map("skill_key")
  mode            ApprovalMode
  thresholdAmount Decimal?     @map("threshold_amount") @db.Decimal(14, 2)
  approverRole    Role?        @map("approver_role")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, skillKey])
  @@index([orgId])
  @@map("approval_policies")
}

/// Which roles may see which document visibility level (tenant-scoped).
/// RLS ENABLE + FORCE. 'open' needs no grant; no grant ⇒ not visible.
model VisibilityGrant {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String             @map("org_id") @db.Uuid
  level     DocumentVisibility
  role      Role
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, level, role])
  @@index([orgId])
  @@map("visibility_grants")
}

/// Tenant-scoped client entity — mutable working state (name/notes change).
/// RLS ENABLE + FORCE. The `[id, org_id]` composite unique is the target of the
/// composite FK from skill_runs, so a run can never reference another tenant's
/// client — structurally, on top of RLS.
model Client {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String
  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  skillRuns    SkillRun[]
  artifacts    Artifact[]

  @@unique([id, orgId])
  @@index([orgId, createdAt(sort: Desc)])
  @@map("clients")
}

/// One execution of a declarative skill (tenant-scoped). RLS ENABLE + FORCE.
/// The `[id, org_id]` unique constraint is the target of the composite FKs from
/// skill_steps/approvals — a step or approval can never reference another
/// tenant's run, structurally, on top of RLS.
model SkillRun {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String         @map("org_id") @db.Uuid
  skillKey  String         @map("skill_key")
  status    SkillRunStatus @default(running)
  /// 'live' (default) or 'simulation' (dry-run). See SkillRunMode.
  mode      SkillRunMode   @default(live)
  input     Json
  result    Json?
  /// Loop acceptance-criteria trace (DeliverableTrace). NULL for runs without criteria.
  trace     Json?
  clientId  String?        @map("client_id") @db.Uuid
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  client       Client?      @relation(fields: [clientId, orgId], references: [id, orgId], onDelete: SetNull)
  steps        SkillStep[]
  approvals    Approval[]
  artifacts    Artifact[]

  @@unique([id, orgId])
  @@index([orgId, createdAt(sort: Desc)])
  // Mode-filtered aggregations (value dashboard): count/list runs by mode.
  @@index([orgId, mode])
  @@map("skill_runs")
}

/// One executed step of a skill run (tenant-scoped). RLS ENABLE + FORCE.
model SkillStep {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String          @map("org_id") @db.Uuid
  runId     String          @map("run_id") @db.Uuid
  idx       Int
  name      String
  status    SkillStepStatus @default(pending)
  detail    Json?
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  run          SkillRun     @relation(fields: [runId, orgId], references: [id, orgId], onDelete: Cascade)

  @@unique([runId, idx])
  @@index([orgId])
  @@map("skill_steps")
}

/// Human approval gate for a guarded skill run (tenant-scoped). RLS ENABLE + FORCE.
model Approval {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String         @map("org_id") @db.Uuid
  runId        String         @map("run_id") @db.Uuid
  reason       String
  status       ApprovalStatus @default(pending)
  /// Role required to decide (from the approval policy). NULL = pre-policy
  /// behavior: any decided_by may decide (kept for runs without a policy).
  requiredRole Role?          @map("required_role")
  decidedBy    String?        @map("decided_by")
  decidedAt    DateTime?      @map("decided_at") @db.Timestamptz(6)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  run          SkillRun     @relation(fields: [runId, orgId], references: [id, orgId], onDelete: Cascade)

  @@index([orgId, status, createdAt])
  @@index([runId])
  @@map("approvals")
}

/// Tenant-scoped. RLS ENABLE + FORCE. org_id NOT NULL + FK.
model Membership {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  userId    String   @map("user_id")
  role      Role     @default(member)
  /// 'clerk' = role mirrors Clerk (overwritten on sync); 'local' = set in
  /// helix.ai (e.g. 'lead') and never touched by a Clerk sync.
  roleSource String  @default("clerk") @map("role_source")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization   Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  slackUserLinks SlackUserLink[]

  @@unique([orgId, userId])
  @@index([orgId])
  @@map("memberships")
}

/// Example tenant table. RLS ENABLE + FORCE. org_id NOT NULL + FK.
model KnowledgeItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  title     String
  body      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("knowledge_items")
}

/// Knowledge-base document (tenant-scoped). RLS ENABLE + FORCE. org_id NOT NULL
/// + FK. The `[id, org_id]` unique constraint exists as the target of the
/// composite FK from `chunks` (a chunk can never reference a foreign tenant's
/// document — structurally, on top of RLS).
model Document {
  id         String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String             @map("org_id") @db.Uuid
  title      String
  source     DocumentSource
  visibility DocumentVisibility @default(open)
  /// Ingestion metadata (0005, all nullable — NULL = pre-0005 / unknown):
  /// original file format ('pdf' | 'docx' | 'md' | 'txt'), PDF page count,
  /// extracted word count.
  sourceFormat String?          @map("source_format")
  pageCount    Int?             @map("page_count")
  wordCount    Int?             @map("word_count")
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  chunks       Chunk[]

  @@unique([id, orgId])
  @@index([orgId, createdAt(sort: Desc)])
  @@map("documents")
}

/// Embedded text chunk of a document (tenant-scoped). RLS ENABLE + FORCE.
/// `embedding` is pgvector's vector(1024) — Prisma cannot express it, so it is
/// declared Unsupported: chunk INSERTs and similarity queries go through
/// $queryRaw inside withTenant() (src/lib/rag/).
model Chunk {
  id         String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String                      @map("org_id") @db.Uuid
  documentId String                      @map("document_id") @db.Uuid
  content    String
  embedding  Unsupported("vector(1024)")
  ord        Int
  createdAt  DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  document     Document     @relation(fields: [documentId, orgId], references: [id, orgId], onDelete: Cascade)

  @@unique([documentId, ord])
  @@index([orgId])
  @@map("chunks")
}

/// Chat history (tenant-scoped). RLS ENABLE + FORCE. org_id NOT NULL + FK.
/// 👍/👎 per (message, voter) — RAG feedback loop (Phase 18). RLS ENABLE+FORCE.
/// Composite FK (message_id, org_id) → chat_messages: cross-tenant votes are
/// structurally impossible. Not audited (product telemetry, not governance).
model ChatFeedback {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  actorId   String   @map("actor_id")
  verdict   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  message      ChatMessage  @relation(fields: [messageId, orgId], references: [id, orgId], onDelete: Cascade)

  @@unique([orgId, messageId, actorId])
  @@index([orgId])
  @@map("chat_feedback")
}

model ChatMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  role      ChatRole
  content   String
  /// Who this turn belongs to (Clerk user id or 'slack:U…'). NULL = pre-0010
  /// row — fail-closed: never part of anyone's multi-turn history.
  actorId   String?  @map("actor_id")
  /// Answer trace (assistant rows, 0021): used sources with scores, threshold,
  /// no-knowledge flag — role-filtered hits only as a bare COUNT, never content.
  trace     Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  feedback     ChatFeedback[]

  @@unique([id, orgId])
  @@index([orgId, createdAt])
  @@index([orgId, actorId, createdAt])
  @@map("chat_messages")
}

/// Append-only audit trail. RLS ENABLE + FORCE. INSERT/SELECT only — UPDATE and
/// DELETE are blocked by both the absence of a policy and a trigger.
model AuditLog {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String    @map("org_id") @db.Uuid
  actorId   String    @map("actor_id")
  actorType ActorType @map("actor_type")
  action    String
  target    String?
  detail    Json?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt(sort: Desc)])
  @@index([orgId, actorId, createdAt(sort: Desc)])
  @@map("audit_log")
}

/// Persistent, versioned deliverable produced by a skill run (tenant-scoped).
/// RLS ENABLE + FORCE. Composite FKs to clients and skill_runs make cross-tenant
/// references structurally impossible. blob_key references external blob storage.
/// Versions with the same slug (org_id, slug) form a version chain: a new run
/// increments version, old versions remain readable.
model Artifact {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  title       String
  type        String
  clientId    String?  @map("client_id") @db.Uuid
  runId       String?  @map("run_id") @db.Uuid
  blobKey     String   @map("blob_key")
  contentType String   @map("content_type")
  sizeBytes   Int      @map("size_bytes")
  version     Int      @default(1)
  slug        String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  client       Client?      @relation(fields: [clientId, orgId], references: [id, orgId], onDelete: SetNull)
  run          SkillRun?    @relation(fields: [runId, orgId], references: [id, orgId], onDelete: SetNull)

  @@unique([id, orgId])
  @@index([orgId, createdAt(sort: Desc)])
  @@index([orgId, clientId])
  @@map("artifacts")
}
