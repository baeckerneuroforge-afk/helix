# =============================================================================
# helix.ai — environment template (DB name/role bleiben intern `ergane`). Copy to `.env` and fill in.  NEVER commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# DATABASE_URL is the connection the APPLICATION (and the Prisma Client, and the
# test suite) uses. It MUST point at the least-privileged role `app_user`.
# app_user is NOT a superuser, is NOT a table owner, and has NOBYPASSRLS — so
# every query it runs is subject to Row-Level Security. This is the whole point.
DATABASE_URL="postgresql://app_user:app_user@localhost:5432/ergane?schema=public"
#
# PRODUCTION / SERVERLESS (Vercel + Neon) — required, not optional:
# Every tenant DB op runs inside an INTERACTIVE transaction (withTenant), which
# pins one connection for its whole duration. On Vercel each concurrent function
# instance keeps its own Prisma pool, so without a pooler + a per-instance cap
# you can exhaust Postgres max_connections under load. Therefore in prod:
#   1. point DATABASE_URL at Neon's POOLED (transaction-mode/PgBouncer) endpoint,
#   2. append `&pgbouncer=true` — disables Prisma's named prepared statements,
#      which transaction pooling cannot keep alive,
#   3. append `&connection_limit=1` (small; tune to the Neon plan) to cap each
#      serverless instance.
#   e.g. DATABASE_URL="postgresql://app_user:***@<pooled-host>/ergane?sslmode=require&pgbouncer=true&connection_limit=1"
# Tenant isolation is unaffected — withTenant() sets the org via a transaction-
# local set_config(is_local:=true), which is correct under transaction pooling.
# Migrations must still use the UNPOOLED endpoint (DIRECT_DATABASE_URL below).

# DIRECT_DATABASE_URL is used ONLY by `prisma migrate` / `prisma db ...` (DDL)
# and by the test harness for resetting state. It connects as the database
# OWNER (a privileged role in local dev). The application never uses this URL.
DIRECT_DATABASE_URL="postgresql://ergane:ergane@localhost:5432/ergane?schema=public"

# -----------------------------------------------------------------------------
# AI providers (knowledge base / RAG) — OPTIONAL for tests and `pnpm demo:rag`.
#
# Both run behind the provider abstraction in src/lib/ai/. Leave the keys unset
# and the code falls back to deterministic FAKE providers (no network calls) —
# that is what CI and the demo script use by default. Set the keys to use the
# real providers. To move to Claude on AWS Bedrock (EU) later, only the adapter
# behind the interface changes — see README "Provider abstraction".
# -----------------------------------------------------------------------------
# Anthropic — chat/answer generation (https://console.anthropic.com).
# Der Key aktiviert ZUSAETZLICH OCR fuer gescannte PDFs (Phase 17) — ohne Key
# werden Scans weiterhin fail-closed abgelehnt.
ANTHROPIC_API_KEY=""
# Override the chat model if needed (default: claude-opus-4-8).
ANTHROPIC_MODEL=""

# Voyage AI — embeddings (https://dash.voyageai.com). Anthropic does not offer
# an embeddings endpoint; Voyage is Anthropic's recommended embeddings partner.
# The schema is fixed to vector(1024) = voyage-3.5's default dimensionality.
VOYAGE_API_KEY=""
# Override the embedding model if needed (default: voyage-3.5; MUST be a model
# that produces 1024-dimensional vectors, or change the migration).
VOYAGE_EMBEDDING_MODEL=""

# -----------------------------------------------------------------------------
# Clerk (https://dashboard.clerk.com) — enable "Organizations" for the instance.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Where Clerk hosts its flows in this app.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# -----------------------------------------------------------------------------
# Slack (zweiter Eingang) — OPTIONAL; nur für die Slack-Integration nötig.
#
# SLACK_SIGNING_SECRET verifiziert JEDE eingehende Slack-Anfrage (HMAC über den
# rohen Body + 5-Minuten-Replay-Fenster). Ohne gültige Signatur: 401, nichts
# wird verarbeitet. SLACK_BOT_TOKEN wird nur zum SENDEN (chat.postMessage)
# gelesen — die Datenbank speichert in slack_installations.bot_token_ref nur
# einen VERWEIS (z. B. "env:SLACK_BOT_TOKEN"), niemals das Secret selbst.
# Beide Werte: Slack-App → Basic Information / OAuth & Permissions.
# `pnpm demo:slack` und die Tests brauchen KEINE echten Werte (sie signieren
# mit einem Test-Secret und fangen ausgehende Nachrichten ab).
# -----------------------------------------------------------------------------
SLACK_SIGNING_SECRET=""
SLACK_BOT_TOKEN=""
# OAuth-Install-Flow (Phase 9) — nur noetig, wenn Workspaces per Button statt
# manueller Team-ID verbunden werden. Client-Daten aus der Slack-App
# (Basic Information); Redirect-URL: https://<host>/api/slack/oauth/callback.
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
# Dedicated HMAC secret for OAuth `state` (CSRF binding orgId+expiry). Prefer
# this over reusing SLACK_SIGNING_SECRET. Generate any long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, code falls back to SLACK_SIGNING_SECRET (temporary compatibility).
SLACK_OAUTH_STATE_SECRET=""
# 32-Byte-Schluessel (base64) fuer die AES-GCM-Verschluesselung von per OAuth
# erhaltenen Bot-Tokens (bot_token_ref 'enc:…'). Einmal erzeugen:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SLACK_TOKEN_ENC_KEY=""

# -----------------------------------------------------------------------------
# Linear connector (read + optional comment write) — OAuth + webhook ingest.
# Redirect URL: https://<host>/api/connectors/linear/oauth/callback
# Webhook URL:  https://<host>/api/connectors/linear/webhook
# Create an OAuth app + webhook signing secret in Linear settings.
# OAuth scopes requested: read, comments:create, write (see LINEAR_OAUTH_SCOPES).
# If Linear was connected before write scopes existed, re-connect so users re-consent.
# Live comments also need HELIX_LINEAR_WRITE (below); otherwise prod refuses writes.
# -----------------------------------------------------------------------------
LINEAR_CLIENT_ID=""
LINEAR_CLIENT_SECRET=""
LINEAR_WEBHOOK_SECRET=""
# Optional dedicated HMAC secret for OAuth state; falls back to CONNECTOR_TOKEN_ENC_KEY
# or SLACK_OAUTH_STATE_SECRET.
LINEAR_OAUTH_STATE_SECRET=""
# Preferred key for encrypting connector OAuth tokens (enc:…). Falls back to
# SLACK_TOKEN_ENC_KEY if unset (same 32-byte base64 format).
CONNECTOR_TOKEN_ENC_KEY=""

# -----------------------------------------------------------------------------
# GitHub connector (read) — OAuth + webhook (push / pull_request).
# Redirect: https://<host>/api/connectors/github/oauth/callback
# Webhook:  https://<host>/api/connectors/github/webhook
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_WEBHOOK_SECRET=""
GITHUB_OAUTH_STATE_SECRET=""

# -----------------------------------------------------------------------------
# Google Drive connector (read) — OAuth + signed ingest webhook.
# Redirect: https://<host>/api/connectors/drive/oauth/callback
# Webhook:  https://<host>/api/connectors/drive/webhook
# -----------------------------------------------------------------------------
DRIVE_CLIENT_ID=""
DRIVE_CLIENT_SECRET=""
# Or GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
DRIVE_WEBHOOK_SECRET=""
DRIVE_OAUTH_STATE_SECRET=""

# -----------------------------------------------------------------------------
# Tool write effects (P3-A) — post Linear comments via skill linear_kommentar.
# Without HELIX_LINEAR_WRITE, production refuses writes; dev/test use a fake.
# Token comes from the org's Linear connector install (enc:…).
# -----------------------------------------------------------------------------
HELIX_LINEAR_WRITE=""

# -----------------------------------------------------------------------------
# Clerk-Webhooks (Svix) — synchronisiert Memberships (Phase 8). OPTIONAL lokal;
# in Produktion Pflicht, sonst behalten entfernte Nutzer ihre lokalen Rechte.
# Clerk Dashboard → Webhooks → Endpoint auf https://<host>/api/clerk/webhooks,
# Events: organizationMembership.*, user.deleted, organization.deleted.
# Der "Signing Secret" des Endpoints (whsec_…) kommt hierher:
# -----------------------------------------------------------------------------
CLERK_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# Effekt-Provider (Phase 11) — echte Skill-Effekte. OPTIONAL: ohne Key nutzen
# dev/Tests den deterministischen Fake (keine Mail verlaesst das System);
# Produktion ohne Key verweigert den Effekt (fail-closed).
# Resend (https://resend.com) fuer E-Mail-Versand mit PDF-Anhang:
RESEND_API_KEY=""
# Verifizierte Absender-Adresse fuer Resend:
EFFECTS_EMAIL_FROM=""

# -----------------------------------------------------------------------------
# Haertung (Phase 16) — beides OPTIONAL.
# CSP: Report-Only ist der Default (beobachten, nichts brechen). Production
# should set CSP_ENFORCE=true after one clean deploy (no console CSP reports):
#   vercel env add CSP_ENFORCE production   # value: true
CSP_ENFORCE=""
# Fehler-Sink: jede logError()-Meldung wird (maskiert) als JSON hierhin
# gePOSTet — Slack-/Discord-Webhook, Alerting-Relay oder Sentry-Forwarder.
# Fuer das volle Sentry-SDK siehe src/lib/error-reporter.ts (Anschlusspunkt).
ERROR_WEBHOOK_URL=""

# -----------------------------------------------------------------------------
# Vercel Cron — schuetzt die geplanten Routen (/api/cron/retention, /api/cron/loop).
# Wird als `Authorization: Bearer <CRON_SECRET>` von Vercel Cron automatisch
# mitgesendet, sobald die Variable im Projekt gesetzt ist. Fail-closed: ist sie
# nicht gesetzt, antworten die Cron-Routen 503 (laufen NIE unauthentifiziert).
# Konstantzeitiger Vergleich in src/lib/cron-auth.ts.
CRON_SECRET=""

# -----------------------------------------------------------------------------
# Demo seed bridge (pnpm seed:demo) — optional. Without these, seed uses the
# built-in Nordwind constants. Set DEMO_CLERK_ORG_ID to your live Clerk org so
# dashboard + seed share the same tenant (see docs/yc-demo-runbook.md).
# -----------------------------------------------------------------------------
DEMO_CLERK_ORG_ID=""
DEMO_ORG_ID=""
DEMO_ORG_NAME=""

# -----------------------------------------------------------------------------
# Artefakt-Speicher (Vercel Blob) — generierte Deliverables (Angebote/Rechnungen).
# Ohne Token nutzen dev/Tests den in-memory Fake (kein Netzwerk); Produktion
# ohne Token verweigert das Speichern (fail-closed). Blobs werden PRIVAT abgelegt
# (access:'private') und nur ueber die RLS-gesicherte Download-Route ausgeliefert.
BLOB_READ_WRITE_TOKEN=""
